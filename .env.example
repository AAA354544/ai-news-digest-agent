DIGEST_TOPIC=AI
DIGEST_LOOKBACK_HOURS=24
MAX_LLM_CANDIDATES=50
MAIN_DIGEST_MIN_ITEMS=10
MAIN_DIGEST_MAX_ITEMS=15

LLM_PROVIDER=zhipu
ZHIPU_API_KEY=your_zhipu_api_key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=your_free_zhipu_model_name

# Reserved/Future provider fields (currently not active in LLMClient):
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=

QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=

GITHUB_TOKEN=your_github_token

SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USE_SSL=true
SENDER_EMAIL=your_email@qq.com
SMTP_AUTH_CODE=your_smtp_authorization_code
RECIPIENT_EMAIL=your_receive_email@qq.com
# RECIPIENT_EMAIL is still used for default CLI send and GitHub Actions schedule.
# Streamlit local recipient management uses data/recipients.local.json.

DEFAULT_SEND_TIME=22:00
TIMEZONE=Asia/Shanghai
